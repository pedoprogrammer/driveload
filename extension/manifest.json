{
  "manifest_version": 3,
  "name": "DriveLoad",
  "version": "1.0.0",
  "description": "Download Google Drive view-only videos directly from your browser.",
  "permissions": ["cookies", "activeTab", "storage", "tabs"],
  "host_permissions": [
    "https://drive.google.com/*",
    "https://*.google.com/*",
    "https://driveload.onrender.com/*"
  ],
  "action": {
    "default_popup": "popup.html",
    "default_icon": {
      "16": "icons/icon16.png",
      "48": "icons/icon48.png",
      "128": "icons/icon128.png"
    }
  },
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  }
}
